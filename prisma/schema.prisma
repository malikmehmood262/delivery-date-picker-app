// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider = "sqlite"
  url      = "file:dev.sqlite"
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model Shop {
  id          String            @id @default(cuid())
  domain      String            @unique
  isActive    Boolean           @default(true)
  plan        String            @default("FREE") // FREE | STANDARD | PREMIUM
  installedAt DateTime          @default(now())
  settings    DeliverySettings?
  deliveries  DeliveryRecord[]
}

model DeliverySettings {
  id                 String           @id @default(cuid())
  shop               Shop             @relation(fields: [shopId], references: [id], onDelete: Cascade)
  shopId             String           @unique
  enabled            Boolean          @default(true)
  leadTimeDays       Int              @default(2)
  cutoffTime         String?          // "14:00" or null
  maxDaysAhead       Int              @default(30)
  blackoutDates      String           @default("[]") // JSON — ["2025-12-25", ...]
  blackoutWeekdays   String           @default("[]") // JSON — [0, 6] = Sun, Sat
  giftMessageEnabled Boolean          @default(false)
  updatedAt          DateTime         @updatedAt
  collectionRules    CollectionRule[]
}

model CollectionRule {
  id             String           @id @default(cuid())
  settings       DeliverySettings @relation(fields: [settingsId], references: [id], onDelete: Cascade)
  settingsId     String
  collectionGid  String           // gid://shopify/Collection/123
  leadTimeDays   Int              @default(2)
  blackoutDates  String           @default("[]")
}

model DeliveryRecord {
  id               String   @id @default(cuid())
  shop             Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  shopId           String
  shopifyOrderId   String   @unique // stored as String; convert from BigInt in webhook
  shopifyOrderName String            // "#1001"
  deliveryDate     DateTime
  giftMessage      String   @default("")
  customerName     String   @default("")
  createdAt        DateTime @default(now())
}
